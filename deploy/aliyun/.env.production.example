# =============================================================================
# uzApi Aliyun Production Environment
# =============================================================================
# Copy to deploy/aliyun/.env.production and edit real secrets on the ECS host.
# NEVER commit .env.production.
# =============================================================================

DOMAIN=api.uzapi.org
HTTP_PORT=80
HTTPS_PORT=443
TZ=China/Hangzhou
SERVER_MODE=release
RUN_MODE=standard

APP_IMAGE=uzapi/uzapi
APP_IMAGE_TAG=aliyun-latest
GOPROXY=https://goproxy.cn,direct
GOSUMDB=sum.golang.google.cn

DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USER=uzapi
DATABASE_PASSWORD=CHANGE_ME_LONG_RANDOM_DB_PASSWORD
DATABASE_DBNAME=uzapi
DATABASE_SSLMODE=disable
DATABASE_MAX_OPEN_CONNS=100
DATABASE_MAX_IDLE_CONNS=20
DATABASE_CONN_MAX_LIFETIME_MINUTES=30
DATABASE_CONN_MAX_IDLE_TIME_MINUTES=5

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_DB=0
REDIS_ENABLE_TLS=false
REDIS_POOL_SIZE=1024
REDIS_MIN_IDLE_CONNS=10

ADMIN_EMAIL=admin@uzapi.local
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD

JWT_SECRET=CHANGE_ME_64_HEX_JWT_SECRET
JWT_EXPIRE_HOUR=24
TOTP_ENCRYPTION_KEY=CHANGE_ME_64_HEX_TOTP_KEY

LOG_LEVEL=info
LOG_FORMAT=json

# OpenAI API Key 通常在后台账号/渠道里配置，不建议写入这个 env 文件。
