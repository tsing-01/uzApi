# =============================================================================
# uzApi Aliyun Production Environment
# =============================================================================
# Copy to deploy/aliyun/.env.production and edit real secrets on the ECS host.
# NEVER commit .env.production.
# =============================================================================

DOMAIN=api.uzapi.org
HTTP_PORT=80
HTTPS_PORT=443
TZ=Asia/Hong_Kong
SERVER_MODE=release
RUN_MODE=standard

# GitHub Actions deployment overrides these with the image built for each commit.
# Prefer Aliyun ACR for ECS deployments to avoid slow cross-border GHCR pulls.
APP_IMAGE=ghcr.io/your-org-or-user/uzapi
APP_IMAGE_TAG=aliyun-latest

DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USER=uzapi
DATABASE_PASSWORD=CHANGE_ME_LONG_RANDOM_DB_PASSWORD
DATABASE_DBNAME=uzapi
DATABASE_SSLMODE=disable
DATABASE_MAX_OPEN_CONNS=100
DATABASE_MAX_IDLE_CONNS=20
DATABASE_CONN_MAX_LIFETIME_MINUTES=30
DATABASE_CONN_MAX_IDLE_TIME_MINUTES=5

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_DB=0
REDIS_ENABLE_TLS=false
REDIS_POOL_SIZE=1024
REDIS_MIN_IDLE_CONNS=10

ADMIN_EMAIL=admin@uzapi.local
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD

JWT_SECRET=CHANGE_ME_64_HEX_JWT_SECRET
JWT_EXPIRE_HOUR=24
TOTP_ENCRYPTION_KEY=CHANGE_ME_64_HEX_TOTP_KEY

LOG_LEVEL=info
LOG_FORMAT=json

# OpenAI API Key 通常在后台账号/渠道里配置，不建议写入这个 env 文件。

# 腾讯云 SES 邮件推送（注册/登录邮箱验证码）。
# 全部填写后，后台「注册设置 → 邮箱验证」开关打开时，验证码通过腾讯云 SES 发送。
# 这些变量通过 compose 的 env_file 自动注入容器，无需改 docker-compose.yml。
TENCENT_SES_SECRET_ID=CHANGE_ME_TENCENT_SECRET_ID
TENCENT_SES_SECRET_KEY=CHANGE_ME_TENCENT_SECRET_KEY
TENCENT_SES_FROM=noreply@uzapi.org
TENCENT_SES_TEMPLATE_ID=CHANGE_ME_TEMPLATE_ID
TENCENT_SES_REGION=ap-guangzhou
# 下面两个变量名必须和腾讯云 SES 模板里声明的占位符一致（模板用 {{otp_code}} 和 {{username}}）。
# TEMPLATE_VARIABLE 接收验证码，USERNAME_VARIABLE 接收展示名（注册场景用收件人邮箱填充）。
TENCENT_SES_TEMPLATE_VARIABLE=otp_code
TENCENT_SES_TEMPLATE_USERNAME_VARIABLE=username
#密码重置也走腾讯 SES（不配则走 SMTP）。需在腾讯 SES 后台单独建一个
TENCENT_SES_RESET_TEMPLATE_ID=54460
TENCENT_SES_RESET_TEMPLATE_VARIABLE=reset_url

# 前端主站地址：用于生成邮件里的密码重置链接（后台「前端地址」留空时用它兜底）。
SERVER_FRONTEND_URL=https://uzapi.org

# 允许跨域访问后端 API 的前端来源，逗号分隔。前端主站(uzapi.org)与后端(api.uzapi.org)
# 不同源时，必须把主站 origin 列进来，否则浏览器会报 CORS error。
CORS_ALLOWED_ORIGINS=https://uzapi.org,https://api.uzapi.org
