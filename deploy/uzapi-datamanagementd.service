[Unit]
Description=uzApi Data Management Daemon
After=network.target
Wants=network.target

[Service]
Type=simple
User=uzapi
Group=uzapi
WorkingDirectory=/opt/uzapi
ExecStart=/opt/uzapi/datamanagementd \
  -socket-path /tmp/uzapi-datamanagement.sock \
  -sqlite-path /var/lib/uzapi/datamanagement/datamanagementd.db \
  -version 1.0.0
Restart=always
RestartSec=5s
LimitNOFILE=100000
NoNewPrivileges=true
PrivateTmp=false

[Install]
WantedBy=multi-user.target
